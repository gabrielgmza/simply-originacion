rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() { return request.auth != null; }
    function uid() { return request.auth.uid; }
    function getUserData() { return get(/databases/$(database)/documents/usuarios/$(uid())).data; }
    function rol() { return getUserData().rol; }
    function entidadId() { return getUserData().entidadId; }
    function esMaster() { return isAuth() && rol() == 'MASTER_PAYSUR'; }
    function esGerente() { return isAuth() && rol() in ['GERENTE_GENERAL', 'GERENTE_SUCURSAL']; }
    function esStaffEntidad(eid) { return isAuth() && entidadId() == eid; }
    function esGerenteEntidad(eid) { return isAuth() && entidadId() == eid && rol() in ['GERENTE_GENERAL', 'GERENTE_SUCURSAL']; }
    function esGerenteGeneral() { return isAuth() && rol() == 'GERENTE_GENERAL'; }

    match /entidades/{eid} {
      allow read:   if esMaster() || esStaffEntidad(eid);
      allow create: if esMaster();
      allow update: if esMaster() || esGerenteEntidad(eid);
      allow delete: if esMaster();
    }

    match /usuarios/{userId} {
      allow read:   if esMaster() || uid() == userId || (esGerente() && resource.data.entidadId == entidadId());
      allow create: if esMaster() || esGerente();
      allow update: if esMaster() || uid() == userId || esGerenteEntidad(resource.data.entidadId);
      allow delete: if esMaster() || esGerenteEntidad(resource.data.entidadId);
    }

    match /sucursales/{sucId} {
      allow read:   if esMaster() || esStaffEntidad(resource.data.entidadId);
      allow write:  if esMaster() || esGerenteEntidad(resource.data.entidadId);
    }

    match /operaciones/{opId} {
      allow read:   if esMaster() || esStaffEntidad(resource.data.entidadId);
      allow create: if isAuth() && rol() in ['VENDEDOR', 'GERENTE_GENERAL', 'GERENTE_SUCURSAL'] && request.resource.data.entidadId == entidadId();
      allow update: if esMaster() || esStaffEntidad(resource.data.entidadId);
      allow delete: if esMaster();
    }

    match /leads/{leadId} {
      allow create: if true;
      allow read:   if esMaster() || esStaffEntidad(resource.data.entidadId);
      allow update: if esMaster() || esStaffEntidad(resource.data.entidadId);
      allow delete: if esMaster();
    }

    match /pagos/{pagoId} {
      allow read:   if esMaster() || esStaffEntidad(resource.data.entidadId);
      allow create: if isAuth() && esStaffEntidad(request.resource.data.entidadId);
      allow update: if esMaster() || esStaffEntidad(resource.data.entidadId);
      allow delete: if esMaster();
    }

    match /recibos/{reciboId} {
      allow read:   if esMaster() || esStaffEntidad(resource.data.entidadId);
      allow create: if isAuth();
      allow update, delete: if esMaster();
    }

    match /fondeadores/{fondId} {
      allow read:   if esMaster() || esStaffEntidad(resource.data.entidadId) || (isAuth() && rol() == 'FONDEADOR' && uid() == resource.data.uid);
      allow write:  if esMaster() || esGerenteEntidad(resource.data.entidadId);
    }

    match /magic_links/{token} {
      allow read:   if true;
      allow create: if isAuth();
      allow update: if true;
      allow delete: if esMaster();
    }

    match /credenciales/{credId} {
      allow read:   if esMaster() || (isAuth() && esGerenteGeneral() && entidadId() == resource.data.entidadId);
      allow write:  if esMaster() || (isAuth() && esGerenteGeneral() && entidadId() == resource.data.entidadId);
    }

    // ── credencialesCuad ──────────────────────────────────────────────────────
    match /credencialesCuad/{credId} {
      allow read:   if esMaster() || esStaffEntidad(resource.data.entidadId);
      allow create: if esMaster() || (isAuth() && esGerenteGeneral() && entidadId() == request.resource.data.entidadId);
      allow update: if esMaster() || (isAuth() && esGerenteGeneral() && entidadId() == resource.data.entidadId);
      allow delete: if esMaster() || (isAuth() && esGerenteGeneral() && entidadId() == resource.data.entidadId);
    }

    match /renovaciones/{renId} {
      allow read:   if esMaster() || esStaffEntidad(resource.data.entidadId);
      allow create: if isAuth() && esStaffEntidad(request.resource.data.entidadId);
      allow update: if esMaster() || esStaffEntidad(resource.data.entidadId);
      allow delete: if esMaster();
    }

    match /certificados/{certId} {
      allow read:   if esMaster() || esStaffEntidad(resource.data.entidadId);
      allow create: if isAuth();
      allow update, delete: if esMaster();
    }

    match /scoring_resultados/{scId} {
      allow read:   if esMaster() || esStaffEntidad(resource.data.entidadId);
      allow create: if isAuth();
      allow update, delete: if esMaster();
    }

    match /notificaciones_internas/{notifId} {
      allow read:   if isAuth() && (uid() == resource.data.usuarioId || esGerenteEntidad(resource.data.entidadId) || esMaster());
      allow create: if isAuth();
      allow update: if isAuth() && uid() == resource.data.usuarioId;
      allow delete: if esMaster();
    }

    match /subastas_fondeo/{subId} {
      allow read:   if esMaster() || esStaffEntidad(resource.data.entidadId) || (isAuth() && rol() == 'FONDEADOR');
      allow create: if isAuth() && esStaffEntidad(request.resource.data.entidadId);
      allow update: if esMaster() || esStaffEntidad(resource.data.entidadId) || (isAuth() && rol() == 'FONDEADOR');
      allow delete: if esMaster();
    }

    match /portal_fondeador/{sesId} {
      allow read, update: if isAuth() && uid() == resource.data.uid;
      allow create: if isAuth();
      allow delete: if esMaster();
    }

    match /logs_operaciones/{logId} {
      allow read:   if esMaster() || esGerenteEntidad(resource.data.entidadId);
      allow create: if isAuth();
      allow update, delete: if esMaster();
    }
    match /logs_cobranzas/{logId} {
      allow read:   if esMaster() || esStaffEntidad(resource.data.entidadId);
      allow create: if isAuth() && esStaffEntidad(request.resource.data.entidadId);
      allow update, delete: if esMaster();
    }
    match /logs_emails/{logId} {
      allow read:   if esMaster() || esGerenteEntidad(resource.data.entidadId);
      allow create: if isAuth();
      allow update, delete: if esMaster();
    }
    match /logs_leads/{logId} {
      allow read:   if esMaster() || esStaffEntidad(resource.data.entidadId);
      allow create: if isAuth();
      allow update, delete: if esMaster();
    }
    match /logs_pagos360/{logId} {
      allow read:   if esMaster() || esGerenteEntidad(resource.data.entidadId);
      allow create: if true;
      allow update, delete: if esMaster();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
